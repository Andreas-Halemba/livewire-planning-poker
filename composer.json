{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "license": "MIT",
    "type": "project",
    "keywords": [
        "framework",
        "laravel"
    ],
    "require": {
        "php": "^8.4",
        "blade-ui-kit/blade-icons": "^1.9.1",
        "codeat3/blade-clarity-icons": "^1.11",
        "guzzlehttp/guzzle": "^7.10.0",
        "inspector-apm/inspector-laravel": "^4.19.0",
        "inspector-apm/inspector-php": "^3.17.1",
        "laravel/framework": "^12.56.0",
        "laravel/pulse": "^1.7.3",
        "laravel/reverb": "^1.10.0",
        "laravel/sanctum": "^4.3.1",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^3.0",
        "lesstif/php-jira-rest-client": "^5.12.1",
        "livewire/livewire": "^3.7.15",
        "pusher/pusher-php-server": "^7.2.7",
        "secondnetwork/blade-tabler-icons": "^3.41.0"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.29.2",
        "ergebnis/composer-normalize": "^2.51",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.2",
        "larastan/larastan": "^3.9.5",
        "laravel/boost": "^2.4.3",
        "laravel/breeze": "^2.4.1",
        "laravel/pint": "^1.29.0",
        "laravel/sail": "^1.57.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.6.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "spatie/laravel-ignition": "^2.12.0",
        "spatie/laravel-ray": "^1.43.7"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "ergebnis/composer-normalize": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "barryvdh/laravel-ide-helper"
            ]
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php -r \"getenv('COMPOSER_DEV_MODE') == 0 || print(exec('php ./vendor/bin/captainhook install -f'));\""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
